{
  "name": "ts-hierarchical-clustering",
  "version": "1.0.9",
  "description": "A TypeScript implementation of AGNES, an agglomerative hierarchical clustering algorithm",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "lint": "eslint src test",
    "lint:fix": "eslint src test --fix",
    "test": "jest",
    "build": "tsc",
    "prepare": "npm run lint && npm run test && npm run build",
    "clean": "rm -r dist; rm -r coverage; rm ts-hierarchical-clustering-*.tgz; echo 'done'"
  },
  "files": [
    "dist/**"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fredooo/ts-hierarchical-clustering.git"
  },
  "keywords": [
    "hierarchical",
    "agglomerative",
    "clustering",
    "algorithm",
    "AGNES"
  ],
  "author": "Frederik Dennig",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
