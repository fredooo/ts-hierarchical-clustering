{
  "compilerOptions": {
    "target": "es2021",
    "module": "node16",
    "lib": [ "es2021", "dom" ],
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "isolatedModules": true
  },
  "include": [ "src" ],
  "exclude": [ "node_modules", "test" ]
}
